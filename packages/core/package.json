{
  "name": "@v43/core",
  "version": "0.1.1",
  "type": "module",
  "description": "V43 runtime — System base class, resource signals, and ECS integration",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": ">=0.150.0",
    "elics": ">=3.0.0",
    "@preact/signals-core": ">=1.0.0"
  },
  "author": "Bela Bohlender",
  "repository": {
    "type": "git",
    "url": "https://github.com/drawcall-ai/v43.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/drawcall-ai/v43#readme",
  "bugs": {
    "url": "https://github.com/drawcall-ai/v43/issues"
  },
  "keywords": [
    "v43",
    "vite",
    "three",
    "threejs",
    "ecs",
    "signals",
    "framework"
  ]
}
