{
  "name": "@v43/plugin",
  "version": "0.1.1",
  "type": "module",
  "description": "V43 combined Vite plugin — includes ws, rpc, cli, editor, three, and drop plugins",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@v43/plugin-ws": "workspace:*",
    "@v43/plugin-rpc": "workspace:*",
    "@v43/plugin-cli": "workspace:*",
    "@v43/plugin-three": "workspace:*",
    "@v43/plugin-drop": "workspace:*",
    "@v43/plugin-editor": "workspace:*"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "author": "Bela Bohlender",
  "repository": {
    "type": "git",
    "url": "https://github.com/drawcall-ai/v43.git",
    "directory": "packages/plugin"
  },
  "homepage": "https://github.com/drawcall-ai/v43#readme",
  "bugs": {
    "url": "https://github.com/drawcall-ai/v43/issues"
  },
  "keywords": [
    "v43",
    "vite",
    "three",
    "threejs",
    "vite-plugin"
  ]
}
